rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: Validate string-based custom IDs to prevent ID Poisoning
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Helper: Access incoming request resource payload
    function incoming() {
      return request.resource.data;
    }

    // Helper: Access existing database resource payload
    function existing() {
      return resource.data;
    }

    // Helper: Verify if user is signed in
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper: Validate string bounds
    function isValidString(val, min, max) {
      return val is string && val.size() >= min && val.size() <= max;
    }

    // Helper: Perform strict schema checks, type checks, and length validations for User Profiles
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'displayName', 'username', 'bio', 'city', 'photoURL', 'createdAt']) &&
             data.keys().size() >= 7 && data.keys().size() <= 11 &&
             data.uid == request.auth.uid &&
             isValidString(data.displayName, 1, 150) &&
             isValidString(data.username, 1, 100) && data.username.matches('^[a-z0-9_\\-]+$') &&
             isValidString(data.bio, 0, 1000) &&
             isValidString(data.city, 0, 500) &&
             isValidString(data.photoURL, 0, 2000) &&
             data.createdAt is int &&
             (!data.keys().hasAll(['email']) || isValidString(data.email, 3, 200)) &&
             (!data.keys().hasAll(['phoneNumber']) || isValidString(data.phoneNumber, 3, 100)) &&
             (!data.keys().hasAll(['provider']) || isValidString(data.provider, 1, 50)) &&
             (!data.keys().hasAll(['lastLogin']) || data.lastLogin is int);
    }

    // 1. GLOBAL SAFETY NET (Default Deny Catch-All)
    match /{document=**} {
      allow read, write: if false;
    }

    // 2. USER PROFILE RULES (Client Direct SDK Allowed)
    match /users/{userId} {
      // Get: Users are only allowed to read their own profile document
      allow get: if isSignedIn() && request.auth.uid == userId;
      
      // List: Allow querying user collection if signed in, validating the resource shape in query limits
      allow list: if isSignedIn() && (
        resource.data.uid == request.auth.uid || 
        (resource.data.username is string && resource.data.username.size() <= 50)
      );
      
      // Create: Users may register a new profile if they are signed in and matching the path variables
      allow create: if isSignedIn() && 
                       userId == request.auth.uid && 
                       isValidId(userId) && 
                       isValidUser(incoming());
                       
      // Update: Users may edit their displayName, username, city, bio, or photoURL.
      // Other fields (uid, createdAt) are marked as immutable.
      allow update: if isSignedIn() && 
                       request.auth.uid == userId && 
                       isValidUser(incoming()) && 
                       incoming().uid == existing().uid && 
                       incoming().createdAt == existing().createdAt && 
                       incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'username', 'city', 'bio', 'photoURL', 'email', 'phoneNumber', 'provider', 'lastLogin']);
                       
      // Delete: Users cannot delete profiles directly via Client SDK
      allow delete: if false;
    }

    // 3. SECURE BACKEND-ONLY ISOLATED COLLECTIONS
    // All direct Client-Side SDK access is disabled.
    // Operations on these collections are securely mediated by the server (server.ts) using the Firebase Admin SDK.
    
    match /posts/{postId} {
      allow read, write: if false;
    }

    match /matches/{matchId} {
      allow read, write: if false;
    }

    match /claims/{claimId} {
      allow read, write: if false;
    }

    match /notifications/{notificationId} {
      allow read, write: if false;
    }

    match /audit_logs/{logId} {
      allow read, write: if false;
    }
  }
}
